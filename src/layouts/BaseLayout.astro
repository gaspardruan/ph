---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Ruan Zhongqiu",
  description = "Ruan Zhongqiu's home website.",
} = Astro.props;
const pageTitle = title === "Ruan Zhongqiu" ? title : `${title} | Ruan Zhongqiu`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/R-black.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Nunito:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (stored === "dark" || (!stored && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch {
          return;
        }
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
