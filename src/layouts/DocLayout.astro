---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocToc from "@/components/DocToc.astro";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  title: string;
  description: string;
  headings: Heading[];
};

const { title, description, headings } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main class="flex-1 bg-nord-background pb-16 pt-32 dark:bg-nord-background-dark md:pb-24">
    <article class="doc-shell prose-doc rounded-lg border border-nord-outline bg-nord-foreground px-5 py-8 shadow-sm dark:border-nord-outline-dark dark:bg-nord-foreground-dark md:px-10 md:py-12">
      <slot />
    </article>
    <DocToc headings={headings} />
  </main>
</BaseLayout>
