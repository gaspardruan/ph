---
import { getCollection } from "astro:content";
import MobileNav from "@/components/react/MobileNav";
import ThemeToggle from "@/components/react/ThemeToggle";

const projects = (await getCollection("project")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<header
  class="fixed inset-x-0 top-0 z-20 border-b border-nord-neutral/10 bg-nord-background/80 px-4 py-4 shadow-sm shadow-nord-background backdrop-blur dark:border-nord-neutral-dark/10 dark:bg-nord-background-dark/80 dark:shadow-nord-background-dark lg:px-10 xl:px-20"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between">
    <a href="/" aria-label="Home" class="flex h-10 w-10 items-center justify-center">
      <img src="/R-black.png" alt="R logo" class="h-10 w-10 dark:invert" />
    </a>

    <nav class="hidden items-center divide-x divide-nord-neutral/10 dark:divide-nord-neutral-dark/10 md:flex">
      <div class="group relative pr-2 lg:pr-6">
        <button
          type="button"
          class="rounded px-3 py-2 text-sm font-semibold transition hover:bg-nord-secondary-deep/10"
        >
          Project
        </button>
        <div
          class="pointer-events-none absolute right-2 top-full min-w-44 translate-y-2 rounded border border-nord-outline bg-nord-foreground p-2 opacity-0 shadow-lg transition group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 dark:border-nord-outline-dark dark:bg-nord-foreground-dark"
        >
          {
            projects.map((project) => (
              <a
                class="block rounded px-3 py-2 text-sm font-medium transition hover:bg-nord-secondary-deep/10"
                href={`/docs/project/${project.id}`}
              >
                {project.data.title}
              </a>
            ))
          }
        </div>
      </div>
      <div class="pl-2 lg:pl-6">
        <ThemeToggle client:load />
      </div>
    </nav>

    <MobileNav
      client:load
      projects={projects.map((project) => ({
        id: project.id,
        title: project.data.title,
      }))}
    />
  </div>
</header>
